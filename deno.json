    "@dui/primitives/data-table": "../dui-primitives/packages/primitives/src/data-table/index.ts",
    "@dui/primitives/dialog": "../dui-primitives/packages/primitives/src/dialog/index.ts",
    "@dui/primitives/dropzone": "../dui-primitives/packages/primitives/src/dropzone/index.ts",
    "@dui/primitives/field": "../dui-primitives/packages/primitives/src/field/index.ts",
    "@dui/primitives/fieldset": "../dui-primitives/packages/primitives/src/fieldset/index.ts",
    "@dui/primitives/icon": "../dui-primitives/packages/primitives/src/icon/index.ts",
