    "@dui/primitives/scroll-area": "../dui-primitives/packages/primitives/src/scroll-area/index.ts",
    "@dui/primitives/select": "../dui-primitives/packages/primitives/src/select/index.ts",
    "@dui/primitives/separator": "../dui-primitives/packages/primitives/src/separator/index.ts",
    "@dui/primitives/sidebar": "../dui-primitives/packages/primitives/src/sidebar/index.ts",
    "@dui/primitives/slider": "../dui-primitives/packages/primitives/src/slider/index.ts",
    "@dui/primitives/spinner": "../dui-primitives/packages/primitives/src/spinner/index.ts",
    "@dui/primitives/split-button": "../dui-primitives/packages/primitives/src/split-button/index.ts",
    "@dui/primitives/stepper": "../dui-primitives/packages/primitives/src/stepper/index.ts",
    "@dui/primitives/switch": "../dui-primitives/packages/primitives/src/switch/index.ts",
    "@dui/primitives/tabs": "../dui-primitives/packages/primitives/src/tabs/index.ts",
    "@dui/primitives/textarea": "../dui-primitives/packages/primitives/src/textarea/index.ts",
    "@dui/primitives/toggle": "../dui-primitives/packages/primitives/src/toggle/index.ts",
    "@dui/primitives/toolbar": "../dui-primitives/packages/primitives/src/toolbar/index.ts",
    "@dui/primitives/tooltip": "../dui-primitives/packages/primitives/src/tooltip/index.ts",
    "@dui/primitives/trunc": "../dui-primitives/packages/primitives/src/trunc/index.ts"
  },
  "unstable": ["raw-imports"],
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "DOM",
      "DOM.Iterable",
      "DOM.AsyncIterable",
      "ESNext"
    ]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all packages/docs/serve.ts",
    "build:docs": "deno run --allow-all packages/docs/serve.ts --build",
    "build": "deno run --allow-all scripts/build.ts",
    "build:cdn": "deno run --allow-all scripts/build-cdn.ts",
    "build:all": "deno run --allow-all scripts/build.ts && deno run --allow-all scripts/build-cdn.ts",
    "version": "deno run --allow-all scripts/version.ts",
    "publish": "deno run --allow-all scripts/publish.ts",
    "publish:live": "deno run --allow-all scripts/publish.ts --publish",
    "gen:skill-refs": "deno run --allow-read --allow-write scripts/generate-skill-refs.ts",
    "design-md": "deno run --allow-read --allow-write --allow-run scripts/generate-design-md.ts",
    "import-design-md": "deno run --allow-read --allow-write scripts/import-design-md.ts",
    "translate-design-md": "deno run --allow-read --allow-write --allow-run --allow-net scripts/translate-design-md.ts"
  }
}
