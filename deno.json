{
  "workspace": [
    "./packages/components",
    "./packages/map",
    "./packages/chart",
    "./packages/templates",
    "./packages/docs"
  ],
  "imports": {
    "lit": "npm:lit@^3.3.2",
    "lit/decorators.js": "npm:/lit@^3.3.2/decorators.js",
    "@lit/context": "npm:@lit/context@^1.1.3",
    "@floating-ui/dom": "npm:@floating-ui/dom@^1.7.4",
    "@deepfuture/dui-inspector": "npm:@deepfuture/dui-inspector@^0.0.22",
