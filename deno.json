    "@dui/primitives/accordion": "../dui-primitives/packages/primitives/src/accordion/index.ts",
    "@dui/primitives/alert-dialog": "../dui-primitives/packages/primitives/src/alert-dialog/index.ts",
    "@dui/primitives/avatar": "../dui-primitives/packages/primitives/src/avatar/index.ts",
    "@dui/primitives/badge": "../dui-primitives/packages/primitives/src/badge/index.ts",
    "@dui/primitives/breadcrumb": "../dui-primitives/packages/primitives/src/breadcrumb/index.ts",
    "@dui/primitives/button": "../dui-primitives/packages/primitives/src/button/index.ts",
    "@dui/primitives/calendar": "../dui-primitives/packages/primitives/src/calendar/index.ts",
    "@dui/primitives/card": "../dui-primitives/packages/primitives/src/card/index.ts",
    "@dui/primitives/card-grid": "../dui-primitives/packages/primitives/src/card-grid/index.ts",
    "@dui/primitives/checkbox": "../dui-primitives/packages/primitives/src/checkbox/index.ts",
    "@dui/primitives/collapsible": "../dui-primitives/packages/primitives/src/collapsible/index.ts",
    "@dui/primitives/combobox": "../dui-primitives/packages/primitives/src/combobox/index.ts",
