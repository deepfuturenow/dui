{
  "workspace": [
    "./packages/core",
    "./packages/components",
    "./packages/theme-default",
    "./packages/docs"
  ],
  "unstable": ["raw-imports"],
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "DOM",
      "DOM.Iterable",
      "DOM.AsyncIterable",
      "ESNext"
    ]
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all packages/docs/serve.ts",
    "build:docs": "deno run --allow-all packages/docs/serve.ts --build"
  }
}
